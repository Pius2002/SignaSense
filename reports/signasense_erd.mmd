erDiagram
    DEVICE_PROFILE ||--o{ CAMERA_USER_SIGN_SAMPLE : owns
    DEVICE_PROFILE ||--o{ MOTION_PHRASE_SAMPLE : owns
    DEVICE_PROFILE ||--o{ GLOVE_LETTER_PATTERN : owns
    DEVICE_PROFILE ||--|| ADAPTIVE_LANGUAGE_SETTINGS : stores
    DEVICE_PROFILE ||--|| THEME_PREFERENCE : stores
    DEVICE_PROFILE ||--o{ WORD_USAGE_COUNT : learns
    DEVICE_PROFILE ||--o{ SENTENCE_USAGE_COUNT : learns

    ALPHABET_LETTER ||--o{ CAMERA_USER_SIGN_SAMPLE : labels
    ALPHABET_LETTER ||--o{ GLOVE_LETTER_PATTERN : labels
    MOTION_PHRASE ||--o{ MOTION_PHRASE_SAMPLE : labels
    DICTIONARY_WORD ||--o{ WORD_USAGE_COUNT : counted_as
    DICTIONARY_SENTENCE ||--o{ SENTENCE_USAGE_COUNT : counted_as
    GESTURE_CLASS ||--o{ BUNDLED_GESTURE_LANDMARK_SAMPLE : contains

    DEVICE_PROFILE {
        string profile_id PK "Logical current phone/app installation"
        string app_name "SignaSense"
        string storage_type "CSV files + SharedPreferences"
    }

    ALPHABET_LETTER {
        string letter PK "A-Z"
    }

    CAMERA_USER_SIGN_SAMPLE {
        string sample_id PK "logical row id"
        string profile_id FK
        string letter FK
        float f0
        float f1
        float f2
        string f3_to_f41 "remaining landmark features"
        string stored_in "user_defined_camera_signs.csv"
    }

    MOTION_PHRASE {
        string phrase PK "HELLO, I, YOU"
    }

    MOTION_PHRASE_SAMPLE {
        string sample_id PK "logical row id"
        string profile_id FK
        string phrase FK
        float f0
        float f1
        float f2
        string f3_to_f14 "remaining motion features"
        string stored_in "user_motion_phrases.csv"
    }

    GLOVE_LETTER_PATTERN {
        string letter PK
        string profile_id FK
        int raw_thumb
        int raw_index
        int raw_middle
        int raw_ring
        int raw_pinky
        int bend_thumb
        int bend_index
        int bend_middle
        int bend_ring
        int bend_pinky
        int tolerance
        int tests_passed
        string stored_in "SharedPreferences patterns_v2"
    }

    ADAPTIVE_LANGUAGE_SETTINGS {
        string profile_id PK
        string mode "AUTO, SLOW_LETTERS, SENTENCE_ONLY"
        long hold_ms
        long gap_ms
        float correction_pressure
        string stored_in "SharedPreferences signasense_adaptive_language"
    }

    WORD_USAGE_COUNT {
        string profile_id FK
        string word FK
        int use_count
        string stored_in "SharedPreferences word_counts"
    }

    SENTENCE_USAGE_COUNT {
        string profile_id FK
        string sentence FK
        int use_count
        string stored_in "SharedPreferences sentence_counts"
    }

    THEME_PREFERENCE {
        string profile_id PK
        string theme_mode "light or dark"
        string stored_in "SharedPreferences signasense_theme_preferences"
    }

    DICTIONARY_WORD {
        string word PK
        string source "assets/sign_language_words.txt"
    }

    DICTIONARY_SENTENCE {
        string sentence PK
        string source "assets/sign_language_phrases.txt"
    }

    GESTURE_CLASS {
        int label_id PK
        string label_name
    }

    BUNDLED_GESTURE_LANDMARK_SAMPLE {
        string sample_id PK "logical row id"
        int label_id FK
        string label_name
        float f0
        float f1
        float f2
        string f3_to_f41 "remaining landmark features"
        string source "assets/gesture_landmarks.csv"
    }
