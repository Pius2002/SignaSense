<?xml version="1.0" encoding="utf-8"?>
<ScrollView xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/assist_background"
    android:clipToPadding="false"
    android:fillViewport="true">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:paddingStart="18dp"
        android:paddingTop="20dp"
        android:paddingEnd="18dp"
        android:paddingBottom="28dp">

        <TextView
            android:id="@+id/titleText"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="@string/app_name"
            android:textColor="@color/assist_text"
            android:textSize="32sp"
            android:textStyle="bold" />

        <TextView
            android:id="@+id/subtitleText"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="8dp"
            android:text="Choose the experience, connect a device, and keep the live output easy to read."
            android:textColor="@color/assist_muted"
            android:textSize="16sp"
            android:lineSpacingExtra="2dp" />

        <com.google.android.material.card.MaterialCardView
            android:id="@+id/themeCard"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="18dp"
            app:cardBackgroundColor="@color/assist_surface"
            app:cardCornerRadius="8dp"
            app:strokeColor="@color/assist_border"
            app:strokeWidth="1dp">

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:padding="16dp">

                <TextView
                    android:id="@+id/themeValue"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:textColor="@color/assist_text"
                    android:textSize="17sp"
                    android:textStyle="bold" />

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="12dp"
                    android:orientation="horizontal">

                    <com.google.android.material.button.MaterialButton
                        android:id="@+id/lightModeButton"
                        android:layout_width="0dp"
                        android:layout_height="54dp"
                        android:layout_weight="1"
                        android:text="Light Mode" />

                    <Space
                        android:layout_width="10dp"
                        android:layout_height="1dp" />

                    <com.google.android.material.button.MaterialButton
                        android:id="@+id/darkModeButton"
                        style="@style/Widget.Material3.Button.OutlinedButton"
                        android:layout_width="0dp"
                        android:layout_height="54dp"
                        android:layout_weight="1"
                        android:text="Dark Mode" />
                </LinearLayout>
            </LinearLayout>
        </com.google.android.material.card.MaterialCardView>

        <com.google.android.material.card.MaterialCardView
            android:id="@+id/modeCard"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="18dp"
            app:cardBackgroundColor="@color/assist_surface"
            app:cardCornerRadius="8dp"
            app:strokeColor="@color/assist_border"
            app:strokeWidth="1dp">

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                    android:padding="20dp">

                <TextView
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:text="Start"
                    android:textColor="@color/assist_text"
                    android:textSize="24sp"
                    android:textStyle="bold" />

                <TextView
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="8dp"
                    android:text="Blind mode starts with voice. Deaf mode starts with visual controls."
                    android:textColor="@color/assist_muted"
                    android:textSize="16sp" />

                <com.google.android.material.button.MaterialButton
                    android:id="@+id/blindButton"
                    android:layout_width="match_parent"
                    android:layout_height="56dp"
                    android:layout_marginTop="16dp"
                    android:text="Blind Audio Interface" />

                <com.google.android.material.button.MaterialButton
                    android:id="@+id/deafButton"
                    style="@style/Widget.Material3.Button.OutlinedButton"
                    android:layout_width="match_parent"
                    android:layout_height="56dp"
                    android:layout_marginTop="12dp"
                    android:text="Deaf Visual Interface" />

                <com.google.android.material.button.MaterialButton
                    android:id="@+id/modeVoiceButton"
                    style="@style/Widget.Material3.Button.TonalButton"
                    android:layout_width="match_parent"
                    android:layout_height="56dp"
                    android:layout_marginTop="12dp"
                    android:text="Speak Choice" />
            </LinearLayout>
        </com.google.android.material.card.MaterialCardView>

        <com.google.android.material.card.MaterialCardView
            android:id="@+id/languageCard"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="16dp"
            android:visibility="gone"
            app:cardBackgroundColor="@color/assist_surface"
            app:cardCornerRadius="8dp"
            app:strokeColor="@color/assist_border"
            app:strokeWidth="1dp">

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                    android:padding="20dp">

                <TextView
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:text="Choose language"
                    android:textColor="@color/assist_text"
                    android:textSize="24sp"
                    android:textStyle="bold" />

                <TextView
                    android:id="@+id/languageHint"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="8dp"
                    android:textColor="@color/assist_muted"
                    android:textSize="15sp" />

                <com.google.android.material.button.MaterialButton
                    android:id="@+id/englishButton"
                    android:layout_width="match_parent"
                    android:layout_height="56dp"
                    android:layout_marginTop="16dp"
                    android:text="1. English" />

                <com.google.android.material.button.MaterialButton
                    android:id="@+id/lugandaButton"
                    style="@style/Widget.Material3.Button.OutlinedButton"
                    android:layout_width="match_parent"
                    android:layout_height="56dp"
                    android:layout_marginTop="12dp"
                    android:text="2. Luganda" />

                <com.google.android.material.button.MaterialButton
                    android:id="@+id/acholiButton"
                    style="@style/Widget.Material3.Button.OutlinedButton"
                    android:layout_width="match_parent"
                    android:layout_height="56dp"
                    android:layout_marginTop="12dp"
                    android:text="3. Acholi" />

                <com.google.android.material.button.MaterialButton
                    android:id="@+id/voiceInputButton"
                    style="@style/Widget.Material3.Button.TonalButton"
                    android:layout_width="match_parent"
                    android:layout_height="56dp"
                    android:layout_marginTop="12dp"
                    android:text="Speak Choice" />

                <com.google.android.material.button.MaterialButton
                    android:id="@+id/repeatPromptButton"
                    style="@style/Widget.Material3.Button.TextButton"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="4dp"
                    android:text="Repeat prompt" />
            </LinearLayout>
        </com.google.android.material.card.MaterialCardView>

        <com.google.android.material.card.MaterialCardView
            android:id="@+id/dashboardCard"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="16dp"
            android:visibility="gone"
            app:cardBackgroundColor="@color/assist_surface"
            app:cardCornerRadius="8dp"
            app:strokeColor="@color/assist_border"
            app:strokeWidth="1dp">

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                    android:padding="20dp">

                <TextView
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:text="Dashboard"
                    android:textColor="@color/assist_text"
                    android:textSize="24sp"
                    android:textStyle="bold" />

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="12dp"
                    android:orientation="horizontal">

                    <TextView
                        android:id="@+id/modeValue"
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_weight="1"
                        android:background="@drawable/badge_surface"
                        android:padding="10dp"
                        android:textColor="@color/assist_text"
                        android:textStyle="bold" />

                    <Space
                        android:layout_width="12dp"
                        android:layout_height="1dp" />

                    <TextView
                        android:id="@+id/languageValue"
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_weight="1"
                        android:background="@drawable/badge_alert"
                        android:padding="10dp"
                        android:textColor="@color/assist_text"
                        android:textStyle="bold" />
                </LinearLayout>

                <TextView
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="16dp"
                    android:text="Assistant status"
                    android:textColor="@color/assist_muted"
                    android:textSize="14sp" />

                <TextView
                    android:id="@+id/assistantStatus"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="4dp"
                    android:background="@drawable/transcript_surface"
                    android:minHeight="56dp"
                    android:padding="12dp"
                    android:textColor="@color/assist_text"
                    android:textSize="17sp" />

                <TextView
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="16dp"
                    android:text="Last heard"
                    android:textColor="@color/assist_muted"
                    android:textSize="14sp" />

                <TextView
                    android:id="@+id/transcriptValue"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="4dp"
                    android:background="@drawable/transcript_surface"
                    android:minHeight="64dp"
                    android:padding="12dp"
                    android:text="Waiting for speech input"
                    android:textColor="@color/assist_text"
                    android:textSize="16sp" />

                <LinearLayout
                    android:id="@+id/stickPanel"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="18dp"
                    android:background="@drawable/panel_surface"
                    android:orientation="vertical"
                    android:padding="14dp">

                    <TextView
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:text="Smart Stick"
                        android:textColor="@color/assist_text"
                        android:textSize="20sp"
                        android:textStyle="bold" />

                    <TextView
                        android:id="@+id/stickConnectionValue"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="8dp"
                        android:text="Not connected"
                        android:textColor="@color/assist_muted"
                        android:textSize="15sp" />

                    <TextView
                        android:id="@+id/stickDistanceValue"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="8dp"
                        android:text="-- cm / -- m"
                        android:textColor="@color/assist_text"
                        android:textSize="26sp"
                        android:textStyle="bold" />

                    <TextView
                        android:id="@+id/stickGuidanceValue"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="4dp"
                        android:background="@drawable/transcript_surface"
                        android:minHeight="56dp"
                        android:padding="12dp"
                        android:text="Waiting for stick status"
                        android:textColor="@color/assist_text"
                        android:textSize="16sp" />

                    <com.google.android.material.button.MaterialButton
                        android:id="@+id/stickRefreshButton"
                        android:layout_width="match_parent"
                        android:layout_height="54dp"
                        android:layout_marginTop="14dp"
                        android:text="Connect Smart Stick Wi-Fi" />

                    <com.google.android.material.button.MaterialButton
                        android:id="@+id/stickScanButton"
                        style="@style/Widget.Material3.Button.OutlinedButton"
                        android:layout_width="match_parent"
                        android:layout_height="54dp"
                        android:layout_marginTop="10dp"
                        android:text="Start Stick Scan" />

                    <com.google.android.material.button.MaterialButton
                        android:id="@+id/stickWifiSettingsButton"
                        style="@style/Widget.Material3.Button.TonalButton"
                        android:layout_width="match_parent"
                        android:layout_height="54dp"
                        android:layout_marginTop="10dp"
                        android:text="Open Wi-Fi Settings" />

                    <com.google.android.material.button.MaterialButton
                        android:id="@+id/stickPageButton"
                        style="@style/Widget.Material3.Button.TextButton"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="6dp"
                        android:text="Open stick page" />
                </LinearLayout>

                <LinearLayout
                    android:id="@+id/blindPanel"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="18dp"
                    android:background="@drawable/panel_surface"
                    android:orientation="vertical"
                    android:padding="14dp"
                    android:visibility="gone">

                    <TextView
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:text="Audio commands"
                        android:textColor="@color/assist_text"
                        android:textSize="20sp"
                        android:textStyle="bold" />

                    <TextView
                        android:id="@+id/blindCommandsValue"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="8dp"
                        android:textColor="@color/assist_muted"
                        android:textSize="15sp" />

                    <com.google.android.material.button.MaterialButton
                        android:id="@+id/blindListenButton"
                        android:layout_width="match_parent"
                        android:layout_height="54dp"
                        android:layout_marginTop="16dp"
                        android:text="Listen Now" />

                    <com.google.android.material.button.MaterialButton
                        android:id="@+id/blindRepeatButton"
                        style="@style/Widget.Material3.Button.OutlinedButton"
                        android:layout_width="match_parent"
                        android:layout_height="54dp"
                        android:layout_marginTop="12dp"
                        android:text="Repeat Guidance" />

                    <com.google.android.material.button.MaterialButton
                        android:id="@+id/blindStickButton"
                        style="@style/Widget.Material3.Button.TonalButton"
                        android:layout_width="match_parent"
                        android:layout_height="54dp"
                        android:layout_marginTop="12dp"
                        android:text="Smart Stick Guide" />

                    <com.google.android.material.button.MaterialButton
                        android:id="@+id/blindGloveButton"
                        style="@style/Widget.Material3.Button.TonalButton"
                        android:layout_width="match_parent"
                        android:layout_height="54dp"
                        android:layout_marginTop="12dp"
                        android:text="Open Smart Glove BLE" />

                    <com.google.android.material.button.MaterialButton
                        android:id="@+id/blindGloveTrainerButton"
                        style="@style/Widget.Material3.Button.OutlinedButton"
                        android:layout_width="match_parent"
                        android:layout_height="54dp"
                        android:layout_marginTop="12dp"
                        android:text="Train Glove Letters" />

                    <com.google.android.material.button.MaterialButton
                        android:id="@+id/blindCameraGloveButton"
                        style="@style/Widget.Material3.Button.OutlinedButton"
                        android:layout_width="match_parent"
                        android:layout_height="54dp"
                        android:layout_marginTop="12dp"
                        android:text="Camera Sign Backup" />

                    <com.google.android.material.button.MaterialButton
                        android:id="@+id/blindHelpButton"
                        style="@style/Widget.Material3.Button.TextButton"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="8dp"
                        android:text="Read commands again" />

                    <com.google.android.material.button.MaterialButton
                        android:id="@+id/switchToVisualButton"
                        style="@style/Widget.Material3.Button.TextButton"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="Switch to visual interface" />
                </LinearLayout>

                <LinearLayout
                    android:id="@+id/deafPanel"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="18dp"
                    android:background="@drawable/panel_surface"
                    android:orientation="vertical"
                    android:padding="14dp"
                    android:visibility="gone">

                    <TextView
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:text="Visual actions"
                        android:textColor="@color/assist_text"
                        android:textSize="20sp"
                        android:textStyle="bold" />

                    <TextView
                        android:id="@+id/deafSummaryValue"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="8dp"
                        android:textColor="@color/assist_muted"
                        android:textSize="15sp" />

                    <com.google.android.material.button.MaterialButton
                        android:id="@+id/deafStickGuideButton"
                        android:layout_width="match_parent"
                        android:layout_height="54dp"
                        android:layout_marginTop="16dp"
                        android:text="Smart Stick Guide" />

                    <com.google.android.material.button.MaterialButton
                        android:id="@+id/deafGloveButton"
                        style="@style/Widget.Material3.Button.OutlinedButton"
                        android:layout_width="match_parent"
                        android:layout_height="54dp"
                        android:layout_marginTop="12dp"
                        android:text="Open Smart Glove BLE" />

                    <com.google.android.material.button.MaterialButton
                        android:id="@+id/deafGloveTrainerButton"
                        style="@style/Widget.Material3.Button.OutlinedButton"
                        android:layout_width="match_parent"
                        android:layout_height="54dp"
                        android:layout_marginTop="12dp"
                        android:text="Train Glove Letters" />

                    <com.google.android.material.button.MaterialButton
                        android:id="@+id/deafCameraGloveButton"
                        style="@style/Widget.Material3.Button.TonalButton"
                        android:layout_width="match_parent"
                        android:layout_height="54dp"
                        android:layout_marginTop="12dp"
                        android:text="Camera Sign Backup" />

                    <com.google.android.material.button.MaterialButton
                        android:id="@+id/deafAudioButton"
                        style="@style/Widget.Material3.Button.TextButton"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="8dp"
                        android:text="Switch to audio interface" />
                </LinearLayout>

                <com.google.android.material.button.MaterialButton
                    android:id="@+id/changeLanguageButton"
                    style="@style/Widget.Material3.Button.OutlinedButton"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="20dp"
                    android:text="Change Language" />

                <com.google.android.material.button.MaterialButton
                    android:id="@+id/resetOnboardingButton"
                    style="@style/Widget.Material3.Button.TextButton"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Start again" />
            </LinearLayout>
        </com.google.android.material.card.MaterialCardView>
    </LinearLayout>
</ScrollView>
